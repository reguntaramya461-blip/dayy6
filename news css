body{
    font-family: Arial;
    background-color: #f2f2f2;
    margin: 0;
    padding: 0;
}

/* Header */
header{
    background-color: darkblue;
    color: white;
    text-align: center;
    padding: 20px;
}

/* Main Layout */
main{
    display: flex;
    margin: 20px;
}

/* News Section */
section{
    width: 70%;
}

article{
    background-color: white;
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 10px;
    border-left: 5px solid blue;
}

article h2{
    color: darkblue;
}

/* Sidebar */
aside{
    width: 30%;
    background-color: white;
    padding: 15px;
    margin-left: 20px;
    border-radius: 10px;
}

aside h2{
    color: darkred;
}

/* List */
ul{
    list-style-type: square;
}

li{
    margin: 10px 0;
}

/* Footer */
footer{
    background-color: black;
    color: white;
    text-align: center;
    padding: 15px;
    margin-top: 20px;
}
